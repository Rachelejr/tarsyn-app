// ============================================================================
// ATTENTION : ne JAMAIS modifier ou publier ce fichier depuis la Console
// Firebase (onglet Rules). Toute modification doit se faire ICI, dans ce
// fichier, puis etre deployee uniquement avec :
//   firebase deploy --only firestore:rules
// Publier manuellement depuis la Console web ECRASE ce fichier sans prevenir
// et fait perdre des regles (paymentGrids, chat, etc.) silencieusement.
// ============================================================================
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    match /members/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.organizerId == request.auth.uid ||
        (
          (!('userId' in resource.data) || resource.data.userId == null) &&
          request.resource.data.userId == request.auth.uid
        )
      );
      allow delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    match /contributions/{contribId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    match /documents/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.resource.data.organizerId == request.auth.uid ||
        request.resource.data.uploadedBy == request.auth.uid
      );
      allow update: if request.auth != null && resource.data.organizerId == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.uploadedBy == request.auth.uid
      );
    }
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        resource.data.reactions is map
      );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    match /testimonials/{testimonialId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if false;
    }
    match /audit_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.resource.data.organizerId == request.auth.uid ||
        request.resource.data.actorId == request.auth.uid
      );
      allow update, delete: if false;
    }
    match /paymentProofs/{proofId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    match /paymentGrids/{gridId} {
      function isPlatformAdmin() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
      }
      function isOrganizerOfGroup(gId) {
        let g = get(/databases/$(database)/documents/groups/$(gId)).data;
        return request.auth.uid == g.organizerId || request.auth.uid == g.get('adminId', null);
      }
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.organizerId == request.auth.uid ||
        isOrganizerOfGroup(resource.data.groupId) ||
        isPlatformAdmin()
      );
      allow create: if request.auth != null && (
        request.resource.data.organizerId == request.auth.uid ||
        isOrganizerOfGroup(request.resource.data.groupId) ||
        isPlatformAdmin()
      );
      allow update, delete: if request.auth != null && (
        resource.data.organizerId == request.auth.uid ||
        isOrganizerOfGroup(resource.data.groupId) ||
        isPlatformAdmin()
      );
      match /memberViews/{memberId} {
        allow read: if request.auth != null && request.auth.uid == memberId;
        allow write: if request.auth != null && (
          isPlatformAdmin() ||
          get(/databases/$(database)/documents/paymentGrids/$(gridId)).data.organizerId == request.auth.uid ||
          isOrganizerOfGroup(get(/databases/$(database)/documents/paymentGrids/$(gridId)).data.groupId)
        );
      }
    }
    match /login_history/{entryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /otp_codes/{userId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow delete: if false;
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds &&
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedFor']) &&
              request.auth.uid in request.resource.data.deletedFor
            ) ||
            (
              request.auth.uid == resource.data.senderId &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedForEveryone', 'text', 'mediaUrl'])
            )
          );
        allow delete: if false;
      }
    }
  }
}
