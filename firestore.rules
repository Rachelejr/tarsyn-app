rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users - chacun peut lire/écrire seulement son propre profil
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Workspaces - lecture/écriture réservée aux membres du workspace
    match /workspaces/{workspaceId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    // Groups - lecture publique (necessaire pour la page d'invitation /join/[code]
    // ou l'utilisateur n'est pas encore connecte), ecriture protegee
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    // Members - lecture publique (necessaire pour la page d'invitation /join/[code]).
    // Ecriture : l'organisateur peut tout faire OU un membre qui n'a pas encore
    // de compte (userId vide) peut s'auto-attribuer son propre userId lors de l'inscription.
    match /members/{memberId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.organizerId == request.auth.uid ||
        (
          (!('userId' in resource.data) || resource.data.userId == null) &&
          request.resource.data.userId == request.auth.uid
        )
      );
      allow delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    // Contributions
    match /contributions/{contribId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    // Documents
    match /documents/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.organizerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.organizerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    // Comments - sur documents. Lecture par membres authentifies, ecriture par l'auteur ou l'organisateur.
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        resource.data.reactions is map
      );
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // Reviews - une note par auteur et par document
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }
    // Audit logs - lecture/ecriture reservees a l'organisateur proprietaire
    match /audit_logs/{logId} {
      allow read: if request.auth != null && resource.data.organizerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.organizerId == request.auth.uid;
      allow update, delete: if false;
    }
    // Payment proofs
    match /paymentProofs/{proofId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }
    // OTP codes - chaque utilisateur ne peut acceder qu'a son propre code 2FA
    match /otp_codes/{userId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
    // Chats - groupe ou prive, acces limite aux participants
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow delete: if false;
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
        allow delete: if false;
      }
    }
  }
}
